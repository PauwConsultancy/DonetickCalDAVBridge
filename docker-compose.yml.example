version: "3.8"

services:
  donetick-caldav:
    build: .
    container_name: donetick-caldav
    ports:
      - "5232:5232"
    environment:
      - Donetick__BaseUrl=http://your-donetick-instance:8080
      - Donetick__ApiKey=your-api-key-here
      - Donetick__PollIntervalSeconds=30
      - CalDav__Username=user                     # CalDAV login username
      - CalDav__Password=changeme                 # CalDAV login password
      - CalDav__CalendarName=Donetick Tasks
      - CalDav__CalendarColor=#4A90D9FF
      - CalDav__ListenPort=5232
      # -- Optional: feature flags --
      # - CalDav__GroupByLabel=true               # Separate list per Donetick label
      # - CalDav__DefaultCalendarName=Algemeen    # Catch-all list name (GroupByLabel)
      # - CalDav__AllDayEvents=true               # Tasks as all-day items (no time)
      # - CalDav__PreserveScheduledTime=true      # Keep original scheduled time on recurring
      # -- Optional: HTTPS (required for Apple Calendar/Reminders) --
      # Tailscale PEM certs:
      # - CalDav__Tls__CertPath=/certs/your-hostname.ts.net.crt
      # - CalDav__Tls__KeyPath=/certs/your-hostname.ts.net.key
      # Or PFX certificate:
      # - CalDav__Tls__PfxPath=/certs/certificate.pfx
      # - CalDav__Tls__PfxPassword=optional-password
    # volumes:
    #   - /path/to/certs:/certs:ro
    logging:
      driver: json-file
      options:
        max-size: "10m"        # Rotate after 10 MB per log file
        max-file: "3"          # Keep at most 3 rotated files (30 MB total)
    restart: unless-stopped
